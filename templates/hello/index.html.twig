{% extends 'base.html.twig' %}

{% block body %}
<h1> Messages </h1>
    <div>
        {% if messages|length > 0 %}
            {% for key, message in messages|slice(0, limit) %}
                <div>
                    <a href="{{ path('app_show_one', { id: key}) }}">{{message.message}}</a>
                </div>     
                {{ include('hello/_message.html.twig') }}
            {% endfor %}
        {% else %}
            <div>
                <p> Nothing here yet </p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
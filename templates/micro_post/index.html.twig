{% extends 'base.html.twig' %}

{% block title %}All messages{% endblock %}

{% block body %}
     {% if posts|length > 0 %}
            {% for post in posts %}
                <div>
                    <a href="{{ path('app_micro_post_show', { post: post.id }) }}">
                        {{ post.title }}
                    </a>
                </div>
            {% endfor %}
        {% else %}
            <div>
                <p> Nothing here yet </p>
            </div>
        {% endif %}
{% endblock %}
